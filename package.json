{
  "name": "directors-prep",
  "version": "1.0.0",
  "description": "Director's Prep — scene blocking and storyboarding tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.directorsprep.app",
    "productName": "Director's Prep",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "assets/**",
      "node_modules/electron-updater/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Action34543",
      "repo": "directors-prep"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Director's Prep"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
